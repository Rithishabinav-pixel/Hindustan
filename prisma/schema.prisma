generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  image     String
  link      String
  createdAt DateTime @default(now())
}

model Service {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  heroTitle       String?
  heroDescription String?
  heroButtonName  String?
  heroButtonLink  String?
  heroImage       String?

  subServicesTitle String?
  subServicesItems Json?

  benefitsTitle       String?
  benefitsDescription String?
  benefitsBgDesktop   String?
  benefitsBgMobile    String?
  benefitsItems       Json?

  productsTitle       String?
  productsDescription String?
  selectedProductIds  Json?

  faqTitle String?
  faqItems Json?

  seoMetaTitle       String?
  seoMetaDescription String?
  seoMetaKeywords    String?
  seoOgTitle         String?
  seoOgDescription   String?
  seoOgImage         String?
  seoCanonicalUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactEnquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model Career {
  id           Int      @id @default(autoincrement())
  jobTitle     String
  location     String
  experience   String
  remuneration String
  slug         String   @unique
  details      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CareerEnquiry {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String?
  jobTitle   String
  resumePath String?
  createdAt  DateTime @default(now())
}

model BlogCategory {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  blogs     BlogPost[]
  createdAt DateTime   @default(now())
}

model BlogPost {
  id               Int            @id @default(autoincrement())
  title            String
  slug             String         @unique
  shortDescription String?
  content          String
  featuredImage    String?
  author           String?        @default("Hindustan Drones")
  tags             Json?
  categories       BlogCategory[]
  publishedAt      DateTime?      @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  seoMetaTitle       String?
  seoMetaDescription String?
  seoMetaKeywords    String?
  seoOgTitle         String?
  seoOgDescription   String?
  seoOgImage         String?
  seoCanonicalUrl    String?
}
